{
  "info": {
    "name": "CarShop",
    "_postman_id": "carshop-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5107"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create Listing with Photos",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/listing",
          "host": ["{{baseUrl}}"],
          "path": ["api", "listing"]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "SellerId",
              "value": "00000000-0000-0000-0000-000000000001",
              "type": "text"
            },
            {
              "key": "CarId",
              "value": "00000000-0000-0000-0000-000000000002",
              "type": "text"
            },
            {
              "key": "City",
              "value": "Almaty",
              "type": "text"
            },
            {
              "key": "Description",
              "value": "Clean car, one owner, no accidents",
              "type": "text"
            },
            {
              "key": "photos",
              "type": "file",
              "src": []
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is a valid GUID', function () {",
              "    var id = pm.response.text().replace(/\"/g, '');",
              "    pm.expect(id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i);",
              "});",
              "",
              "pm.test('Content-Type is application/json', function () {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
